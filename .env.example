# REDCap Configuration
# Set VITE_REDCAP_MODE to "mock" for demo mode or "live" for real REDCap
VITE_REDCAP_MODE=mock

# These are only needed when VITE_REDCAP_MODE=live
# Set these in Netlify environment variables (not in this file)
REDCAP_API_URL=https://your-redcap-instance.edu/api/
REDCAP_API_TOKEN=your-api-token-here
